VELOX_ENV=local

# Public URL used by the frontend and by backend-generated path deployment URLs.
PUBLIC_API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:5173

# Use "path" for /deployments/:id or "subdomain" for https://:id.your-domain.
DEPLOYMENT_URL_MODE=path
PUBLIC_DEPLOYMENT_BASE_DOMAIN=

# Internal container routing.
DEPLOYMENT_HOST=host.docker.internal
BUILDKIT_HOST=docker-container://buildkit

# Automatic cleanup for old deployment records and logs.
DEPLOYMENT_TTL_DAYS=5
CLEANUP_INTERVAL_MS=3600000

# Caddy listens on this port for local development.
CADDY_HTTP_PORT=8080

# Production-only Caddy values.
API_DOMAIN=
